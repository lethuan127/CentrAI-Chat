generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────

enum Role {
  ADMIN
  DEVELOPER
  USER
}

enum AuthProvider {
  LOCAL
  GOOGLE
  GITHUB
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

// ─── Workspace (v1: single default, v2: multi-tenant) ──────

model Workspace {
  id        String   @id @default(uuid())
  name      String   @default("Default")
  slug      String   @unique @default("default")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  agents        Agent[]
  conversations Conversation[]

  @@map("workspaces")
}

// ─── User ───────────────────────────────────────────────────

model User {
  id            String       @id @default(uuid())
  workspaceId   String
  workspace     Workspace    @relation(fields: [workspaceId], references: [id])
  email         String       @unique
  passwordHash  String?
  name          String?
  avatar        String?
  role          Role         @default(USER)
  authProvider  AuthProvider @default(LOCAL)
  oauthId       String?
  emailVerified Boolean      @default(false)
  isActive      Boolean      @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  refreshTokens RefreshToken[]
  agents        Agent[]        @relation("AgentCreator")
  agentVersions AgentVersion[] @relation("AgentVersionCreator")
  conversations Conversation[]
  messages      Message[]

  @@unique([authProvider, oauthId])
  @@index([workspaceId])
  @@index([email])
  @@map("users")
}

// ─── Refresh Token ──────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ─── Agent ───────────────────────────────────────────────────

enum AgentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Agent {
  id                       String      @id @default(uuid())
  workspaceId              String
  workspace                Workspace   @relation(fields: [workspaceId], references: [id])
  name                     String
  description              String?
  role                     String      @db.Text
  instructions             String      @db.Text
  expectedOutput           String?     @db.Text
  modelId                  String?
  modelProvider            String?
  modelTemperature         Float       @default(0.7)
  modelMaxTokens           Int?
  addSessionStateToContext Boolean     @default(false)
  maxTurnsMessageHistory    Int?
  enableSessionSummaries   Boolean     @default(false)
  tools                    Json        @default("[]")
  tags                     String[]    @default([])
  status                   AgentStatus @default(DRAFT)
  version                  Int         @default(1)
  createdBy                String
  creator                  User        @relation("AgentCreator", fields: [createdBy], references: [id])
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt
  deletedAt                DateTime?

  versions      AgentVersion[]
  conversations Conversation[]

  @@index([workspaceId])
  @@index([status])
  @@index([createdBy])
  @@map("agents")
}

model AgentVersion {
  id                       String   @id @default(uuid())
  agentId                  String
  agent                    Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  version                  Int
  name                     String
  description              String?
  role                     String   @db.Text
  instructions             String   @db.Text
  expectedOutput           String?  @db.Text
  modelId                  String?
  modelProvider            String?
  modelTemperature         Float
  modelMaxTokens           Int?
  addSessionStateToContext Boolean
  maxTurnsMessageHistory    Int?
  enableSessionSummaries   Boolean
  tools                    Json     @default("[]")
  tags                     String[] @default([])
  changelog                String?
  createdBy                String
  creator                  User     @relation("AgentVersionCreator", fields: [createdBy], references: [id])
  createdAt                DateTime @default(now())

  @@unique([agentId, version])
  @@index([agentId])
  @@map("agent_versions")
}

// ─── Conversation ────────────────────────────────────────────

model Conversation {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  agentId     String?
  agent       Agent?    @relation(fields: [agentId], references: [id])
  modelId     String?
  providerId  String?
  title       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  messages Message[]

  @@index([userId])
  @@index([workspaceId])
  @@index([agentId])
  @@index([createdAt])
  @@map("conversations")
}

// ─── Message ─────────────────────────────────────────────────

model Message {
  id             String      @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?       @relation(fields: [userId], references: [id])
  role           MessageRole
  content        String      @db.Text
  tokenCount     Int?
  createdAt      DateTime    @default(now())

  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}
