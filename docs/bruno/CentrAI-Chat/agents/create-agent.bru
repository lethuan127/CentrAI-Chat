meta {
  name: Create Agent
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/agents
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "My Assistant",
    "description": "A helpful assistant",
    "role": "You are a helpful assistant.",
    "instructions": "Be concise and accurate.",
    "tags": ["demo"]
  }
}
