# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://centrai:centrai@localhost:5432/centrai_chat?schema=public"

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-random-64-char-string"
JWT_REFRESH_SECRET="change-me-to-another-random-64-char-string"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ─── OAuth (Google) ──────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/api/v1/auth/google/callback"

# ─── OAuth (GitHub) ──────────────────────────────────────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_CALLBACK_URL="http://localhost:4000/api/v1/auth/github/callback"

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ─── API ─────────────────────────────────────────────────────
API_PORT=4000
CORS_ORIGIN="http://localhost:3000"

# ─── Encryption (for provider API keys at rest) ─────────────
ENCRYPTION_KEY="change-me-32-byte-hex-key-here"

# ─── LLM Provider (Phase 3 — Chat) ──────────────────────────
# Default model used when no model is specified
DEFAULT_MODEL="gpt-4o-mini"

# OpenAI-compatible provider (set base URL + API key)
# For OpenAI: https://api.openai.com/v1
# For Ollama: http://localhost:11434/v1
# For any OpenAI-compatible API: set the base URL
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"

# Or use a single generic provider (overrides model-specific detection)
# PROVIDER_API_KEY=""
# PROVIDER_BASE_URL=""

# Anthropic (mapped to OpenAI-compatible format)
# ANTHROPIC_API_KEY=""

# Google Gemini
# GOOGLE_API_KEY=""
