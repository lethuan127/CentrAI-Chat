# ╔══════════════════════════════════════════════════════════════╗
# ║  CentrAI-Chat — Environment Configuration                  ║
# ║                                                             ║
# ║  Copy to .env and fill in the required values.              ║
# ║  For Docker self-host: only the sections marked [REQUIRED]  ║
# ║  need to be set. Everything else has sensible defaults.     ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── Database [REQUIRED for local dev, auto-set in Docker] ───
# Docker Compose sets this automatically via service names.
# For local dev, point to your Postgres instance.
DATABASE_URL="postgresql://centrai:centrai@localhost:5432/centrai_chat?schema=public"

# ─── Mastra PostgreSQL (optional; API does not read these until you wire it) ──
# Chat uses Prisma only today. To use Mastra Memory + PostgresStore, add a Nest provider that calls
# `createCentrAiPostgresStore` from `@centrai/agent` and pass `postgresStore` into `createCentrAiChatStream`.
# See: https://mastra.ai/reference/storage/postgresql
# Example vars you might introduce then: MASTRA_PG_ENABLED, MASTRA_PG_SCHEMA, MASTRA_PG_DISABLE_INIT

# ─── Redis [REQUIRED for local dev, auto-set in Docker] ──────
REDIS_URL="redis://localhost:6379"

# ─── JWT [REQUIRED] ─────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET="change-me-to-a-random-64-char-string"
JWT_REFRESH_SECRET="change-me-to-another-random-64-char-string"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ─── Encryption [REQUIRED] ──────────────────────────────────
# Used to encrypt provider API keys at rest.
# Must be a 64-char hex string (32 bytes). Generate with: openssl rand -hex 32
ENCRYPTION_KEY="change-me-32-byte-hex-key-here"

# ─── OAuth (Google) [OPTIONAL] ──────────────────────────────
# Leave blank to disable Google sign-in.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/api/v1/auth/google/callback"

# ─── OAuth (GitHub) [OPTIONAL] ──────────────────────────────
# Leave blank to disable GitHub sign-in.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_CALLBACK_URL="http://localhost:4000/api/v1/auth/github/callback"

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ─── API ─────────────────────────────────────────────────────
API_PORT=4000
CORS_ORIGIN="http://localhost:3000"

# ─── Swagger / API Docs [OPTIONAL] ───────────────────────────
# Set to "false" to disable Swagger UI and OpenAPI JSON in production.
SWAGGER_ENABLED="true"

# ─── LLM Providers [OPTIONAL — configure via admin UI] ──────
# Default model used when no DB provider is configured
DEFAULT_MODEL="gpt-4o-mini"

# OpenAI-compatible provider (set base URL + API key)
# For OpenAI: https://api.openai.com/v1
# For Ollama: http://localhost:11434/v1
# For any OpenAI-compatible API: set the base URL
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"

# Anthropic (mapped to OpenAI-compatible format)
# ANTHROPIC_API_KEY=""

# Google Gemini
# GOOGLE_API_KEY=""

# ═══════════════════════════════════════════════════════════════
# Docker Compose Configuration
# These are only used when running via docker compose.
# ═══════════════════════════════════════════════════════════════

# ─── Postgres container ──────────────────────────────────────
POSTGRES_USER=centrai
POSTGRES_PASSWORD=centrai
POSTGRES_DB=centrai_chat
POSTGRES_PORT=5432

# ─── Redis container ─────────────────────────────────────────
REDIS_PORT=6379

# ─── MinIO container (S3-compatible storage) ─────────────────
MINIO_ROOT_USER=centrai
MINIO_ROOT_PASSWORD=centrai123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── Exposed service ports ───────────────────────────────────
WEB_PORT=3000
# API_PORT is already defined above (4000)
